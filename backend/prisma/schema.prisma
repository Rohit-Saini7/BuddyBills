generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String             @id @default(uuid(7))
  email             String             @unique
  name              String?
  avatarUrl         String?
  provider          String?
  providerId        String?
  passwordHash      String?
  updatedAt         DateTime           @updatedAt
  deleted           Boolean            @default(false)
  pushSubscriptions PushSubscription[]

  @@unique([provider, providerId])
}

model Group {
  id          String        @id @default(uuid(7))
  name        String
  description String?
  updatedAt   DateTime      @updatedAt
  deleted     Boolean       @default(false)
  expenses    Expense[]
  invites     GroupInvite[]
  members     GroupMember[]
  settlements Settlement[]
}

model GroupMember {
  id        String   @id @default(uuid(7))
  groupId   String
  userId    String
  role      String   @default("MEMBER")
  updatedAt DateTime @updatedAt
  deleted   Boolean  @default(false)
  group     Group    @relation(fields: [groupId], references: [id])

  @@unique([groupId, userId])
}

model Expense {
  id          String         @id @default(uuid(7))
  groupId     String
  paidById    String
  amount      Float
  description String
  splitType   String         @default("EQUAL")
  updatedAt   DateTime       @updatedAt
  deleted     Boolean        @default(false)
  group       Group          @relation(fields: [groupId], references: [id])
  splits      ExpenseSplit[]
}

model ExpenseSplit {
  id        String   @id @default(uuid(7))
  expenseId String
  userId    String
  amount    Float
  updatedAt DateTime @updatedAt
  deleted   Boolean  @default(false)
  expense   Expense  @relation(fields: [expenseId], references: [id])
}

model Settlement {
  id         String   @id @default(uuid(7))
  groupId    String
  fromUserId String
  toUserId   String
  amount     Float
  note       String?
  updatedAt  DateTime @updatedAt
  deleted    Boolean  @default(false)
  group      Group    @relation(fields: [groupId], references: [id])
}

model PushSubscription {
  id        String   @id @default(uuid(7))
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model GroupInvite {
  id        String    @id @default(uuid(7))
  groupId   String
  token     String    @unique
  createdBy String
  expiresAt DateTime?
  usedAt    DateTime?
  usedBy    String?
  createdAt DateTime  @default(now())
  group     Group     @relation(fields: [groupId], references: [id])
}
